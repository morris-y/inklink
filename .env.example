# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require

# Work configuration
BOOK_SLUG=my-book
BOOK_TITLE=My Amazing Book

# Git commit info (auto-set by Vercel/build)
GIT_COMMIT_SHA=
GIT_COMMIT_MESSAGE=
GIT_COMMIT_AUTHOR=
GIT_COMMIT_CREATED_AT=

# Dashboard auth (optional - leave unset for open dashboard)
AUTHOR_DASH_PASSWORD=
AUTHOR_DASH_COOKIE_SECRET=change-me-in-production

# Base URL for generating invite links
NEXT_PUBLIC_BASE_URL=http://localhost:3000
